FROM python:3.12-slim

WORKDIR /build
COPY scripts/build_plugin.py scripts/build_plugin.py
COPY scripts/shared/ scripts/shared/
COPY src/des/ src/des/
COPY nWave/ nWave/
COPY pyproject.toml pyproject.toml

RUN pip install --quiet pyyaml

# Build the COMPLETE plugin (includes templates, hooks, DES module)
RUN python scripts/build_plugin.py --output-dir /tmp/plugin 2>/dev/null; \
    echo "Plugin build exit: $?"

# Simulate Claude Code plugin cache installation
RUN mkdir -p /root/.claude/plugins/cache/nwave-marketplace/nw/2.6.0 && \
    cp -r /tmp/plugin/* /root/.claude/plugins/cache/nwave-marketplace/nw/2.6.0/

# Verify plugin structure
RUN echo "=== Plugin structure ===" && \
    find /root/.claude/plugins/cache/nwave-marketplace/nw/2.6.0/ -type f | head -20

# Write the test script
RUN cat > /tmp/test_plugin_hooks.py << 'PYEOF'
import os, sys, subprocess

results = []

DISCOVERY = (
    "import os,sys;"
    "from pathlib import Path;"
    "r=os.environ.get('CLAUDE_PLUGIN_ROOT','');"
    "p=r+'/scripts' if r else '';"
    "p=p or next((str(s) for s in sorted("
    "Path.home().joinpath('.claude/plugins/cache').glob('*/nw/*/scripts'))"
    " if (s/'des'/'__init__.py').exists()),None);"
    "p=p or str(Path.home()/'.claude/lib/python');"
    "sys.path.insert(0,p);"
    "sys.argv=['des-hook','{action}'];"
    "from des.adapters.drivers.hooks.claude_code_hook_adapter import main;"
    "main()"
)

env_without = os.environ.copy()
env_without.pop("CLAUDE_PLUGIN_ROOT", None)

tests = [
    ("pre-tool-use", "{}"),
    ("pre-task", '{"tool_input":{"prompt":"test"}}'),
    ("pre-write", '{"tool_input":{"file_path":"/tmp/test.py"}}'),
    ("pre-edit", '{"tool_input":{"file_path":"/tmp/test.py","old_string":"a","new_string":"b"}}'),
    ("session-start", "{}"),
    ("subagent-stop", '{"tool_input":{"result":"done"}}'),
]

for action, stdin_data in tests:
    r = subprocess.run(
        ["python3", "-c", DISCOVERY.format(action=action)],
        input=stdin_data, capture_output=True, text=True, env=env_without
    )
    if r.returncode == 0:
        results.append((action, "PASS", r.stdout.strip()[:80]))
    else:
        err = r.stdout.strip() or r.stderr.strip()
        results.append((action, "FAIL", err[:120]))

# Also test WITH CLAUDE_PLUGIN_ROOT (ideal case)
env_with = os.environ.copy()
env_with["CLAUDE_PLUGIN_ROOT"] = "/root/.claude/plugins/cache/nwave-marketplace/nw/2.6.0"
r = subprocess.run(
    ["python3", "-c", DISCOVERY.format(action="pre-task")],
    input='{}', capture_output=True, text=True, env=env_with
)
if r.returncode == 0:
    results.append(("pre-task (WITH PLUGIN_ROOT)", "PASS", r.stdout.strip()[:80]))
else:
    results.append(("pre-task (WITH PLUGIN_ROOT)", "FAIL", (r.stdout or r.stderr).strip()[:120]))

print()
print("=" * 70)
print("PLUGIN HOOK DISCOVERY TEST (workaround for bug #24529)")
print("All tests run WITHOUT CLAUDE_PLUGIN_ROOT unless noted")
print("=" * 70)
all_pass = True
for name, status, detail in results:
    icon = "PASS" if status == "PASS" else "FAIL"
    print(f"  [{icon}] {name}")
    if detail:
        print(f"         {detail}")
    if status == "FAIL":
        all_pass = False
print("=" * 70)
if all_pass:
    print("ALL TESTS PASSED — Workaround is production-ready")
else:
    print("SOME TESTS FAILED — Check details above")
sys.exit(0 if all_pass else 1)
PYEOF

RUN python /tmp/test_plugin_hooks.py

CMD ["echo", "done"]
