FROM python:3.12-slim

ARG OPENAI_API_KEY

# Install pipx and basic tools
RUN pip install --no-cache-dir pipx && \
    pipx ensurepath

# Install Node.js (required for OpenCode)
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl git && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install OpenCode
RUN npm install -g opencode-ai

# Create test user (non-root)
RUN useradd -m -s /bin/bash tester
USER tester
WORKDIR /home/tester

# Install nwave-ai via pipx
RUN pipx install nwave-ai

# Configure OpenCode with ChatGPT model
RUN mkdir -p /home/tester/.config/opencode && \
    echo '{"model": "openai/gpt-4o-mini"}' > /home/tester/.config/opencode/opencode.json

# Set API key at runtime (not baked into image)
ENV OPENAI_API_KEY=${OPENAI_API_KEY}

# Verification script
COPY --chown=tester:tester <<'VERIFY' /home/tester/verify.sh
#!/bin/bash
PASS=0
FAIL=0

echo "=== nWave OpenCode Install Verification ==="
echo ""

# 1. OpenCode installed
echo "[1/4] OpenCode version:"
OC_VERSION=$(opencode --version 2>&1 || echo "NOT_FOUND")
echo "  $OC_VERSION"
if [[ "$OC_VERSION" != "NOT_FOUND" ]]; then ((PASS++)); else ((FAIL++)); fi

# 2. nwave-ai installed
echo ""
echo "[2/4] nwave-ai version:"
NW_VERSION=$(~/.local/bin/nwave-ai version 2>&1 || echo "NOT_FOUND")
echo "  $NW_VERSION"
if [[ "$NW_VERSION" != "NOT_FOUND" ]]; then ((PASS++)); else ((FAIL++)); fi

# 3. OpenCode config exists
echo ""
echo "[3/4] OpenCode config:"
if [[ -f ~/.config/opencode/opencode.json ]]; then
    ((PASS++)); echo "  OK: config found"
    cat ~/.config/opencode/opencode.json
else
    ((FAIL++)); echo "  FAIL: config not found"
fi

# 4. API key set
echo ""
echo "[4/4] API key configured:"
if [[ -n "$OPENAI_API_KEY" ]]; then
    ((PASS++)); echo "  OK: OPENAI_API_KEY is set (${#OPENAI_API_KEY} chars)"
else
    ((FAIL++)); echo "  FAIL: OPENAI_API_KEY not set"
fi

echo ""
echo "=== Results: $PASS passed, $FAIL failed ==="
exit $FAIL
VERIFY
RUN chmod +x /home/tester/verify.sh

CMD ["/home/tester/verify.sh"]
