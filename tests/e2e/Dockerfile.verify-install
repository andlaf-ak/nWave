FROM python:3.12-slim

# Install pipx and basic tools
RUN pip install --no-cache-dir pipx && \
    pipx ensurepath

# Install Node.js (required for Claude Code)
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl git && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install Claude Code
RUN npm install -g @anthropic-ai/claude-code

# Create test user (non-root)
RUN useradd -m -s /bin/bash tester
USER tester
WORKDIR /home/tester

# Install nwave-ai via pipx (same as end user)
RUN pipx install nwave-ai

# Verification script
COPY --chown=tester:tester <<'VERIFY' /home/tester/verify.sh
#!/bin/bash
PASS=0
FAIL=0

echo "=== nWave PyPI Install Verification ==="
echo ""

# 1. Check pipx reports correct version
echo "[1/5] pipx package version:"
VERSION=$(pipx list 2>&1 | grep -oP 'nwave-ai \K[0-9.]+' || echo "NOT_FOUND")
echo "  nwave-ai $VERSION"
if [[ "$VERSION" != "NOT_FOUND" ]]; then ((PASS++)); else ((FAIL++)); echo "  FAIL: nwave-ai not in pipx"; fi

# 2. Check CLI version
echo ""
echo "[2/5] nwave-ai CLI version:"
CLI_VERSION=$(~/.local/bin/nwave-ai version 2>&1 || echo "ERROR")
echo "  $CLI_VERSION"
if echo "$CLI_VERSION" | grep -q "$VERSION"; then ((PASS++)); else ((FAIL++)); echo "  FAIL: CLI version mismatch"; fi

# 3. Check no stale "nwave" package
echo ""
echo "[3/5] Stale 'nwave' package check:"
if python3 -c "from importlib.metadata import version; version('nwave')" 2>/dev/null; then
    ((FAIL++)); echo "  FAIL: stale 'nwave' package found"
else
    ((PASS++)); echo "  OK: no 'nwave' package"
fi

# 4. Check shared hook_definitions module is in the wheel
echo ""
echo "[4/5] Shared hook_definitions module present:"
PIPX_VENV=$(pipx list --json 2>/dev/null | python3 -c "import json,sys; d=json.load(sys.stdin); print(list(d['venvs']['nwave-ai']['metadata']['main_package']['app_paths'].values())[0][0])" 2>/dev/null | xargs dirname | xargs dirname || echo "")
if [[ -n "$PIPX_VENV" ]]; then
    SITE=$(dirname "$(dirname "$PIPX_VENV")")/lib/python*/site-packages
    if ls $SITE/scripts/shared/hook_definitions.py 2>/dev/null; then
        ((PASS++)); echo "  OK: hook_definitions.py found"
    else
        ((FAIL++)); echo "  FAIL: hook_definitions.py not in wheel"
    fi
else
    # Fallback: find it directly
    if find ~/.local -name "hook_definitions.py" -path "*/scripts/shared/*" 2>/dev/null | head -1 | grep -q .; then
        ((PASS++)); echo "  OK: hook_definitions.py found"
    else
        ((FAIL++)); echo "  FAIL: hook_definitions.py not in wheel"
    fi
fi

# 5. Version consistency (pipx == CLI)
echo ""
echo "[5/5] Version consistency:"
if [[ "$VERSION" != "NOT_FOUND" ]]; then
    ((PASS++)); echo "  OK: consistent"
else
    ((FAIL++)); echo "  FAIL: cannot verify"
fi

echo ""
echo "=== Results: $PASS passed, $FAIL failed ==="
exit $FAIL
VERIFY
RUN chmod +x /home/tester/verify.sh

CMD ["/home/tester/verify.sh"]
