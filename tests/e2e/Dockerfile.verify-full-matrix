FROM python:3.12-slim AS base

RUN apt-get update && apt-get install -y --no-install-recommends git pipx && rm -rf /var/lib/apt/lists/*
RUN useradd -m tester
USER tester
WORKDIR /home/tester

# Copy source for CLI install tests
COPY --chown=tester:tester . /home/tester/nwave-dev/

# Install pipx and nwave-ai from PyPI
RUN pipx install nwave-ai

# Write comprehensive test script
RUN cat > /home/tester/test_matrix.py << 'PYEOF'
#!/usr/bin/env python3
"""nWave Installation Matrix Test Suite.

Tests all installation methods, upgrade paths, logging, and health check
across simulated Linux/macOS/Windows path conventions.
"""
import json
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

RESULTS = []
TOTAL = 0
FAILED = 0

def test(name, condition, detail=""):
    global TOTAL, FAILED
    TOTAL += 1
    if condition:
        RESULTS.append(("PASS", name, detail))
    else:
        FAILED += 1
        RESULTS.append(("FAIL", name, detail))

def run(cmd, **kwargs):
    return subprocess.run(cmd, shell=True, capture_output=True, text=True, **kwargs)

# ============================================================
# SECTION 1: PyPI/pipx Installation
# ============================================================
print("\n=== SECTION 1: PyPI/pipx Installation ===\n")

r = run("pipx list | grep nwave-ai")
test("pipx: nwave-ai installed", "nwave-ai" in r.stdout, r.stdout.strip())

r = run("~/.local/bin/nwave-ai --version 2>/dev/null || echo 'no version flag'")
test("pipx: CLI accessible", r.returncode == 0 or "no version flag" in r.stdout)

# Verify no stale 'nwave' package (only nwave-ai)
r = run("pip list 2>/dev/null | grep -E '^nwave ' || echo 'clean'")
test("pipx: no stale 'nwave' package", "clean" in r.stdout)

# ============================================================
# SECTION 2: CLI Source Install (nwave-ai install equivalent)
# ============================================================
print("\n=== SECTION 2: CLI Source Install ===\n")

os.chdir("/home/tester/nwave-dev")

# Create venv for source install
r = run("python -m venv /tmp/nwave-venv && /tmp/nwave-venv/bin/pip install pyyaml -q")
test("venv: created for source install", r.returncode == 0)

# Run installer
env = os.environ.copy()
env["VIRTUAL_ENV"] = "/tmp/nwave-venv"
env["PATH"] = "/tmp/nwave-venv/bin:" + env["PATH"]
r = run(
    "python scripts/install/install_nwave.py",
    env=env, cwd="/home/tester/nwave-dev"
)
test("cli-install: completed successfully", "installed and healthy" in r.stdout, r.stdout[-200:])
test("cli-install: no validation errors", "Validation failed" not in r.stdout)

# Verify skill layout (nw-*/SKILL.md flat format)
home = Path.home()
skills_dir = home / ".claude" / "skills"
nw_skills = [d for d in skills_dir.iterdir() if d.is_dir() and d.name.startswith("nw-")] if skills_dir.exists() else []
test("cli-install: skills in nw-*/SKILL.md format", len(nw_skills) > 80, f"{len(nw_skills)} skills")

# Verify no old nw/ directory
old_nw = skills_dir / "nw"
test("cli-install: no old nw/ directory", not old_nw.exists())

# Verify agents
agents_dir = home / ".claude" / "agents" / "nw"
agent_count = len(list(agents_dir.glob("*.md"))) if agents_dir.exists() else 0
test("cli-install: agents installed", agent_count >= 20, f"{agent_count} agents")

# Verify commands
commands_dir = home / ".claude" / "commands" / "nw"
cmd_count = len(list(commands_dir.glob("*.md"))) if commands_dir.exists() else 0
test("cli-install: commands installed", cmd_count >= 20, f"{cmd_count} commands")

# Verify templates
templates_dir = home / ".claude" / "templates"
test("cli-install: templates installed", templates_dir.exists() and any(templates_dir.iterdir()))

# Verify canary skill
canary = skills_dir / "nw-canary" / "SKILL.md"
test("cli-install: canary skill present", canary.exists())
if canary.exists():
    content = canary.read_text()
    test("cli-install: canary passphrase intact", "NWAVE_SKILL_INJECTION_ACTIVE_2026" in content)

# Verify DES module
des_dir = home / ".claude" / "lib" / "python" / "des"
test("cli-install: DES module installed", des_dir.exists())

# ============================================================
# SECTION 3: Health Check
# ============================================================
print("\n=== SECTION 3: Health Check ===\n")

r = run(
    f"PYTHONPATH={home}/.claude/lib/python python -m des.cli.health_check",
    cwd="/home/tester/nwave-dev"
)
test("health-check: exits 0 (healthy)", r.returncode == 0, r.stdout.strip()[-200:])
test("health-check: version reported", "version" in r.stdout.lower() and "FAIL" not in r.stdout.split("version")[0][-20:])
test("health-check: skills counted", "skills" in r.stdout)

# JSON output
r = run(
    f"PYTHONPATH={home}/.claude/lib/python python -m des.cli.health_check --json",
    cwd="/home/tester/nwave-dev"
)
if r.returncode == 0:
    try:
        data = json.loads(r.stdout)
        test("health-check: JSON valid", True)
        test("health-check: JSON status healthy", data.get("status") == "healthy")
    except json.JSONDecodeError:
        test("health-check: JSON valid", False, "invalid JSON")
else:
    test("health-check: JSON output", False, r.stderr[:100])

# ============================================================
# SECTION 4: Logging On/Off
# ============================================================
print("\n=== SECTION 4: Logging On/Off ===\n")

logs_dir = home / ".nwave" / "logs"

# Default: logging disabled
if logs_dir.exists():
    shutil.rmtree(logs_dir)
r = run(
    f"PYTHONPATH={home}/.claude/lib/python python -m des.cli.health_check",
    cwd="/home/tester/nwave-dev"
)
log_files = list(logs_dir.glob("nwave-*.jsonl")) if logs_dir.exists() else []
test("logging-off: no JSONL files by default", len(log_files) == 0, f"{len(log_files)} files")

# Enable logging
if logs_dir.exists():
    shutil.rmtree(logs_dir)
env_log = os.environ.copy()
env_log["NW_LOG"] = "true"
env_log["NW_LOG_LEVEL"] = "DEBUG"
# Run a DES hook to generate log entries
r = run(
    f'echo \'{{}}\' | PYTHONPATH={home}/.claude/lib/python NW_LOG=true NW_LOG_LEVEL=DEBUG python -m des.adapters.drivers.hooks.claude_code_hook_adapter pre-tool-use',
    cwd="/home/tester/nwave-dev"
)
test("logging-on: hook responds", r.returncode == 0, r.stdout.strip()[:80])

# Check if log file was created (depends on hook wiring)
log_files = list(logs_dir.glob("nwave-*.jsonl")) if logs_dir.exists() else []
# Note: logging may not be wired into hooks yet (Increment 2 of design)
if log_files:
    test("logging-on: JSONL file created", True, str(log_files[0]))
    content = log_files[0].read_text()
    test("logging-on: file has content", len(content) > 0)
else:
    test("logging-on: JSONL not yet wired (expected)", True, "Hook logging is Increment 2")

# ============================================================
# SECTION 5: Upgrade from Old Layout
# ============================================================
print("\n=== SECTION 5: Upgrade from Old Layout ===\n")

# Simulate old layout: create skills/nw/software-crafter/tdd-methodology.md
old_skills = skills_dir / "nw" / "software-crafter"
old_skills.mkdir(parents=True, exist_ok=True)
(old_skills / "tdd-methodology.md").write_text("# Old TDD Methodology")

test("upgrade: old layout simulated", old_skills.exists())

# Re-run installer
r = run(
    "python scripts/install/install_nwave.py",
    env=env, cwd="/home/tester/nwave-dev"
)
test("upgrade: install succeeds", "installed and healthy" in r.stdout)

# Verify old layout removed
test("upgrade: old nw/ dir cleaned", not (skills_dir / "nw").exists())

# Verify new layout present
nw_skills_after = [d for d in skills_dir.iterdir() if d.is_dir() and d.name.startswith("nw-")]
test("upgrade: new nw-*/SKILL.md present", len(nw_skills_after) > 80, f"{len(nw_skills_after)} skills")

# ============================================================
# SECTION 6: Plugin Build Verification
# ============================================================
print("\n=== SECTION 6: Plugin Build ===\n")

r = run(
    "python scripts/build_plugin.py --output-dir /tmp/plugin-test",
    env=env, cwd="/home/tester/nwave-dev"
)
test("plugin-build: succeeds", "built successfully" in r.stdout, r.stdout[-150:])

# Check plugin structure
plugin_dir = Path("/tmp/plugin-test")
if plugin_dir.exists():
    plugin_skills = [d for d in (plugin_dir / "skills").iterdir() if d.is_dir() and d.name.startswith("nw-")] if (plugin_dir / "skills").exists() else []
    test("plugin-build: skills in nw-* format", len(plugin_skills) > 50, f"{len(plugin_skills)} skills")
    test("plugin-build: no private agents leaked", not any(
        f.name.startswith("nw-workshopper") for f in (plugin_dir / "agents").glob("*.md")
    ) if (plugin_dir / "agents").exists() else True)
    hooks_json = plugin_dir / "hooks" / "hooks.json"
    test("plugin-build: hooks.json exists", hooks_json.exists())
    if hooks_json.exists():
        hooks = json.loads(hooks_json.read_text())
        test("plugin-build: hooks.json has events", "hooks" in hooks and len(hooks["hooks"]) >= 4)
else:
    test("plugin-build: output dir exists", False)

# ============================================================
# SECTION 7: Build Distribution Verification
# ============================================================
print("\n=== SECTION 7: Build Distribution ===\n")

r = run(
    "python scripts/build_dist.py",
    env=env, cwd="/home/tester/nwave-dev"
)
test("build-dist: succeeds", r.returncode == 0, r.stdout[-100:] if r.returncode == 0 else r.stderr[-100:])

dist_dir = Path("/home/tester/nwave-dev/dist")
if dist_dir.exists():
    dist_skills = dist_dir / "skills"
    if dist_skills.exists():
        nw_dirs = [d for d in dist_skills.iterdir() if d.is_dir() and d.name.startswith("nw-")]
        test("build-dist: skills in nw-* flat format", len(nw_dirs) > 50, f"{len(nw_dirs)} skills")
    else:
        test("build-dist: skills dir exists", False)
else:
    test("build-dist: dist dir exists", False)

# ============================================================
# REPORT
# ============================================================
print("\n" + "=" * 70)
print(f"nWave Installation Matrix Test Results")
print("=" * 70)
for status, name, detail in RESULTS:
    icon = "PASS" if status == "PASS" else "FAIL"
    line = f"  [{icon}] {name}"
    if detail:
        line += f" — {detail[:80]}"
    print(line)
print("=" * 70)
print(f"TOTAL: {TOTAL} tests, {TOTAL - FAILED} passed, {FAILED} failed")
if FAILED == 0:
    print("ALL TESTS PASSED")
else:
    print(f"{FAILED} TESTS FAILED")
sys.exit(0 if FAILED == 0 else 1)
PYEOF

RUN chmod +x /home/tester/test_matrix.py

CMD ["python", "/home/tester/test_matrix.py"]
