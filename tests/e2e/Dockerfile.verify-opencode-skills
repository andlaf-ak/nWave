FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends git curl && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install OpenCode
RUN npm install -g opencode-ai

RUN useradd -m tester
USER tester
WORKDIR /home/tester

COPY --chown=tester:tester . /home/tester/nwave-dev/

# Configure OpenCode
RUN mkdir -p /home/tester/.config/opencode && \
    echo '{"model": "openai/gpt-4o-mini"}' > /home/tester/.config/opencode/opencode.json

RUN cat > /home/tester/test_opencode.py << 'PYEOF'
"""OpenCode skill installation verification."""
import json
import os
import subprocess
import sys
from pathlib import Path

RESULTS = []
TOTAL = 0
FAILED = 0

def test(name, condition, detail=""):
    global TOTAL, FAILED
    TOTAL += 1
    if condition:
        RESULTS.append(("PASS", name, detail))
    else:
        FAILED += 1
        RESULTS.append(("FAIL", name, detail))

def run(cmd, **kw):
    return subprocess.run(cmd, shell=True, capture_output=True, text=True, **kw)

os.chdir("/home/tester/nwave-dev")

# Create venv
run("python -m venv /tmp/venv && /tmp/venv/bin/pip install pyyaml -q")
env = os.environ.copy()
env["VIRTUAL_ENV"] = "/tmp/venv"
env["PATH"] = "/tmp/venv/bin:" + env["PATH"]

# Run installer
r = run("python scripts/install/install_nwave.py", env=env)
test("install: succeeds", "installed and healthy" in r.stdout)

home = Path.home()

# OpenCode skills
oc_skills = home / ".config" / "opencode" / "skills"
if oc_skills.exists():
    dirs = [d for d in oc_skills.iterdir() if d.is_dir()]
    test("opencode-skills: directory populated", len(dirs) > 50, f"{len(dirs)} skill dirs")

    # Check SKILL.md format
    with_skillmd = [d for d in dirs if (d / "SKILL.md").exists()]
    test("opencode-skills: all have SKILL.md", len(with_skillmd) == len(dirs), f"{len(with_skillmd)}/{len(dirs)}")

    # Check manifest
    manifest = oc_skills / ".nwave-manifest.json"
    if manifest.exists():
        mdata = json.loads(manifest.read_text())
        test("opencode-skills: manifest present", "installed_skills" in mdata, f"{len(mdata.get('installed_skills',[]))} tracked")
        test("opencode-skills: manifest version", mdata.get("version") == "1.0")
    else:
        test("opencode-skills: manifest present", False)

    # No private skills
    private = [d.name for d in dirs if any(p in d.name for p in ["workshopper", "tutorialist", "deal-closer", "outreach", "ux-designer", "business-discoverer", "business-reviewer"])]
    test("opencode-skills: no private skills leaked", len(private) == 0, f"leaked: {private}" if private else "clean")

    # Spot-check content
    tdd = oc_skills / "nw-tdd-methodology"
    if tdd.exists():
        sm = tdd / "SKILL.md"
        test("opencode-skills: tdd-methodology has content", sm.exists() and sm.stat().st_size > 100)
    else:
        # OpenCode might not use nw- prefix
        non_prefixed = oc_skills / "tdd-methodology"
        if non_prefixed.exists():
            test("opencode-skills: tdd-methodology (non-prefixed)", True, "uses agent-prefixed name")
        else:
            test("opencode-skills: tdd-methodology found", False)
else:
    test("opencode-skills: directory exists", False, str(oc_skills))

# OpenCode agents
oc_agents = home / ".config" / "opencode" / "agents"
if oc_agents.exists():
    agent_files = list(oc_agents.rglob("*.md"))
    test("opencode-agents: installed", len(agent_files) > 0, f"{len(agent_files)} agents")
else:
    test("opencode-agents: directory exists", False)

# OpenCode commands
oc_cmds = home / ".config" / "opencode" / "commands"
if oc_cmds.exists():
    cmd_files = list(oc_cmds.rglob("*.md"))
    test("opencode-commands: installed", len(cmd_files) > 0, f"{len(cmd_files)} commands")
else:
    test("opencode-commands: directory exists", False)

# Claude Code skills (should also be installed)
cc_skills = home / ".claude" / "skills"
nw_skills = [d for d in cc_skills.iterdir() if d.is_dir() and d.name.startswith("nw-")] if cc_skills.exists() else []
test("claude-code-skills: also installed", len(nw_skills) > 100, f"{len(nw_skills)} skills")

# Report
print("\n" + "=" * 70)
print("OpenCode Installation Test Results")
print("=" * 70)
for status, name, detail in RESULTS:
    icon = "PASS" if status == "PASS" else "FAIL"
    line = f"  [{icon}] {name}"
    if detail:
        line += f" — {detail[:80]}"
    print(line)
print("=" * 70)
print(f"TOTAL: {TOTAL} tests, {TOTAL - FAILED} passed, {FAILED} failed")
if FAILED == 0:
    print("ALL TESTS PASSED")
else:
    print(f"{FAILED} TESTS FAILED")
sys.exit(0 if FAILED == 0 else 1)
PYEOF

CMD ["python", "/home/tester/test_opencode.py"]
