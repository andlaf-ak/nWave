FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*
RUN useradd -m tester
USER tester
WORKDIR /home/tester

COPY --chown=tester:tester . /home/tester/nwave-dev/

RUN cat > /home/tester/test_cross_platform.py << 'PYEOF'
"""Cross-platform and OpenCode installation verification."""
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

RESULTS = []
TOTAL = 0
FAILED = 0

def test(name, condition, detail=""):
    global TOTAL, FAILED
    TOTAL += 1
    if condition:
        RESULTS.append(("PASS", name, detail))
    else:
        FAILED += 1
        RESULTS.append(("FAIL", name, detail))

def run(cmd, **kw):
    return subprocess.run(cmd, shell=True, capture_output=True, text=True, **kw)

os.chdir("/home/tester/nwave-dev")

# ============================================================
# SECTION 1: macOS Simulation (python3 only, no python)
# ============================================================
print("\n=== SECTION 1: macOS Simulation (python3 only) ===\n")

# On macOS, only python3 exists. Test our portable pattern.
r = run("$(command -v python3 || command -v python) --version")
test("macos: portable python resolves", r.returncode == 0, r.stdout.strip())

# Test DES CLI with portable pattern
r = run(
    "PYTHONPATH=src $(command -v python3 || command -v python) -m des.cli.health_check --json"
)
if r.returncode == 0:
    data = json.loads(r.stdout)
    test("macos: health check works", data.get("status") == "healthy")
else:
    test("macos: health check works", False, r.stderr[:100])

# Test hook adapter with portable pattern
r = run(
    "echo '{}' | PYTHONPATH=src $(command -v python3 || command -v python) -m des.adapters.drivers.hooks.claude_code_hook_adapter pre-tool-use"
)
test("macos: hook adapter responds", '{"decision"' in r.stdout, r.stdout.strip()[:50])

# ============================================================
# SECTION 2: Windows Simulation (python only, no python3)
# ============================================================
print("\n=== SECTION 2: Windows Simulation (python alias) ===\n")

# Create a python alias to simulate Windows (python exists, python3 may not)
# On this container python3 exists, so the fallback pattern works both ways
r = run("command -v python3 && echo 'python3 exists' || echo 'no python3'")
test("windows: portable pattern handles both", r.returncode == 0)

# Test that all DES CLI commands use portable pattern (no bare python3)
r = run("grep -rn 'python3 -m des' nwave-dev/nWave/tasks/nw/ 2>/dev/null | grep -v 'command -v' | grep -v '#' || echo 'CLEAN'",
        cwd="/home/tester")
test("windows: no bare python3 in commands", "CLEAN" in r.stdout, r.stdout.strip()[:80])

# Test skill files don't reference bare python3
r = run("grep -rn 'python3 -m des' nwave-dev/nWave/skills/ 2>/dev/null | grep -v 'command -v' | grep -v '#' || echo 'CLEAN'",
        cwd="/home/tester")
test("windows: no bare python3 in skills", "CLEAN" in r.stdout)

# ============================================================
# SECTION 3: OpenCode Installation
# ============================================================
print("\n=== SECTION 3: OpenCode Installation ===\n")

# Create venv for install
r = run("python -m venv /tmp/oc-venv && /tmp/oc-venv/bin/pip install pyyaml -q")
env = os.environ.copy()
env["VIRTUAL_ENV"] = "/tmp/oc-venv"
env["PATH"] = "/tmp/oc-venv/bin:" + env["PATH"]

# Run installer (installs both Claude Code and OpenCode targets)
r = run("python scripts/install/install_nwave.py", env=env, cwd="/home/tester/nwave-dev")
test("opencode: installer succeeds", "installed and healthy" in r.stdout)

# Check OpenCode skills directory
oc_skills = Path.home() / ".config" / "opencode" / "skills"
if oc_skills.exists():
    oc_skill_dirs = [d for d in oc_skills.iterdir() if d.is_dir()]
    test("opencode: skills installed", len(oc_skill_dirs) > 50, f"{len(oc_skill_dirs)} skills")

    # Check SKILL.md format
    sample = next((d / "SKILL.md" for d in oc_skill_dirs if (d / "SKILL.md").exists()), None)
    test("opencode: SKILL.md format", sample is not None, str(sample) if sample else "no SKILL.md")

    # Check manifest
    manifest = oc_skills / ".nwave-manifest.json"
    if manifest.exists():
        mdata = json.loads(manifest.read_text())
        test("opencode: manifest exists", "installed_skills" in mdata, f"{len(mdata.get('installed_skills', []))} tracked")
    else:
        test("opencode: manifest exists", False, "no manifest")

    # Check no private agents leaked
    private_skills = [d.name for d in oc_skill_dirs if "workshopper" in d.name or "tutorialist" in d.name or "deal-closer" in d.name]
    test("opencode: no private skills", len(private_skills) == 0, f"leaked: {private_skills}" if private_skills else "clean")
else:
    test("opencode: skills directory exists", False, "~/.config/opencode/skills/ not found")
    # Still check if OpenCode plugin ran at all
    test("opencode: SKILL.md format", False, "skipped")
    test("opencode: manifest exists", False, "skipped")
    test("opencode: no private skills", True, "skipped (no dir)")

# Check OpenCode agents
oc_agents = Path.home() / ".config" / "opencode" / "agents"
if oc_agents.exists():
    oc_agent_files = list(oc_agents.rglob("*.md"))
    test("opencode: agents installed", len(oc_agent_files) > 0, f"{len(oc_agent_files)} agents")
else:
    test("opencode: agents installed", False, "no agents dir")

# Check OpenCode commands
oc_commands = Path.home() / ".config" / "opencode" / "commands"
if oc_commands.exists():
    oc_cmd_files = list(oc_commands.rglob("*.md"))
    test("opencode: commands installed", len(oc_cmd_files) > 0, f"{len(oc_cmd_files)} commands")
else:
    test("opencode: commands installed", False, "no commands dir")

# ============================================================
# SECTION 4: Skill Content Integrity
# ============================================================
print("\n=== SECTION 4: Skill Content Integrity ===\n")

home = Path.home()
claude_skills = home / ".claude" / "skills"

# Spot-check: tdd-methodology content is non-empty
tdd = claude_skills / "nw-tdd-methodology" / "SKILL.md"
if tdd.exists():
    content = tdd.read_text()
    test("integrity: tdd-methodology has content", len(content) > 100, f"{len(content)} chars")
    test("integrity: has frontmatter", content.startswith("---"))
else:
    test("integrity: tdd-methodology exists", False)

# Spot-check: canary passphrase
canary = claude_skills / "nw-canary" / "SKILL.md"
if canary.exists():
    content = canary.read_text()
    test("integrity: canary passphrase", "NWAVE_SKILL_INJECTION_ACTIVE_2026" in content)
else:
    test("integrity: canary exists", False)

# Check no empty SKILL.md files
empty_skills = []
for skill_dir in claude_skills.iterdir():
    if skill_dir.is_dir() and skill_dir.name.startswith("nw-"):
        sm = skill_dir / "SKILL.md"
        if sm.exists() and sm.stat().st_size == 0:
            empty_skills.append(skill_dir.name)
test("integrity: no empty SKILL.md files", len(empty_skills) == 0, f"empty: {empty_skills[:5]}" if empty_skills else "all non-empty")

# ============================================================
# REPORT
# ============================================================
print("\n" + "=" * 70)
print("Cross-Platform & OpenCode Test Results")
print("=" * 70)
for status, name, detail in RESULTS:
    icon = "PASS" if status == "PASS" else "FAIL"
    line = f"  [{icon}] {name}"
    if detail:
        line += f" — {detail[:80]}"
    print(line)
print("=" * 70)
print(f"TOTAL: {TOTAL} tests, {TOTAL - FAILED} passed, {FAILED} failed")
if FAILED == 0:
    print("ALL TESTS PASSED")
else:
    print(f"{FAILED} TESTS FAILED")
sys.exit(0 if FAILED == 0 else 1)
PYEOF

CMD ["python", "/home/tester/test_cross_platform.py"]
