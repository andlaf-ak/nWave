# Smoke test: Verify production hotfix batch (v3.4.0rc4)
#
# Tests:
# 1. #34: hook allow path produces no stdout
# 2. #33: enforcement regex doesn't false-positive on dates
# 3. #32: .nwave/ gets .gitignore after install
# 4. #29: user skills survive reinstall
# 5. Privacy: no private files (DES source, analysis docs) in wheel
#
# Build:  docker build --no-cache -f tests/e2e/Dockerfile.verify-hotfix-batch -t nwave-hotfix-verify .
# Run:    docker run --rm nwave-hotfix-verify

FROM python:3.12-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir pipx && \
    pipx ensurepath

RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

RUN useradd -m -s /bin/bash tester
USER tester
WORKDIR /home/tester

# Install nwave-ai RC from PyPI
RUN pipx install --pip-args="--pre" nwave-ai

# Create minimal Claude Code environment
RUN mkdir -p /home/tester/.claude && \
    printf '{"permissions": {}, "hooks": {}}\n' > /home/tester/.claude/settings.json

# Create a git repo for install context
RUN git init /home/tester/project && \
    cd /home/tester/project && \
    git config user.email "test@test.com" && \
    git config user.name "Tester" && \
    echo "# test" > README.md && \
    git add -A && \
    git commit -m "init"

# Run nwave-ai install
RUN cd /home/tester/project && \
    ~/.local/bin/nwave-ai install 2>&1 || echo "Install exited with $?"

COPY --chown=tester:tester <<'TEST' /home/tester/test.sh
#!/bin/bash
set -eo pipefail

PASS=0
FAIL=0

check() {
    local name="$1"
    local condition="$2"
    if eval "$condition"; then
        ((PASS++)) || true
        echo "  [PASS] $name"
    else
        ((FAIL++)) || true
        echo "  [FAIL] $name"
    fi
}

echo ""
echo "============================================================"
echo "  nWave Hotfix Batch Verification (v3.4.0rc4)"
echo "============================================================"
echo ""

# --- TEST 1: #34 Hook allow path produces no stdout ---
echo "--- Test 1: Hook allow path silent (#34) ---"

# Find the Python in pipx venv
NWAVE_PYTHON=$(find ~/.local/share/pipx/venvs/nwave-ai -name "python3" -path "*/bin/*" 2>/dev/null | head -1)
if [ -z "$NWAVE_PYTHON" ]; then
    NWAVE_PYTHON=$(find ~/.local/share/pipx -name "python3" -path "*/bin/*" 2>/dev/null | head -1)
fi

if [ -n "$NWAVE_PYTHON" ]; then
    SITE_PKG=$(find "$(dirname "$(dirname "$NWAVE_PYTHON")")" -name "site-packages" -type d 2>/dev/null | head -1)
    LIB_PATH="$SITE_PKG/src"

    # Invoke pre_tool_use with non-DES input
    HOOK_STDOUT=$(echo '{"tool_name": "Read", "tool_input": {"file_path": "/tmp/test.txt"}}' | \
        PYTHONPATH="$LIB_PATH" "$NWAVE_PYTHON" -m des.adapters.drivers.hooks.claude_code_hook_adapter pre-tool-use 2>/dev/null || true)

    check "#34: PreToolUse allow produces no stdout" \
        '[ -z "$HOOK_STDOUT" ]'

    if [ -n "$HOOK_STDOUT" ]; then
        echo "    Got: $HOOK_STDOUT"
    fi
else
    echo "  [SKIP] Cannot find nwave Python interpreter"
fi

# --- TEST 2: #33 Regex doesn't false-positive on dates ---
echo ""
echo "--- Test 2: Enforcement regex no false positives (#33) ---"

if [ -n "$NWAVE_PYTHON" ] && [ -n "$SITE_PKG" ]; then
    # Send a prompt with a date that looks like step-id
    DATE_STDOUT=$(echo '{"tool_name": "Agent", "tool_input": {"prompt": "Fix the issue reported on 03-29 by the QA team"}}' | \
        PYTHONPATH="$LIB_PATH" "$NWAVE_PYTHON" -m des.adapters.drivers.hooks.claude_code_hook_adapter pre-tool-use 2>/dev/null || true)
    DATE_EXIT=$?

    check "#33: Date 03-29 in prompt does NOT trigger enforcement" \
        '[ -z "$DATE_STDOUT" ] && [ "$DATE_EXIT" -eq 0 ]'

    if [ -n "$DATE_STDOUT" ]; then
        echo "    Got: $DATE_STDOUT (exit $DATE_EXIT)"
    fi

    # Verify real step-id still caught
    STEP_STDOUT=$(echo '{"tool_name": "Agent", "tool_input": {"prompt": "Execute step 04-02 of the roadmap"}}' | \
        PYTHONPATH="$LIB_PATH" "$NWAVE_PYTHON" -m des.adapters.drivers.hooks.claude_code_hook_adapter pre-tool-use 2>/dev/null || true)
    STEP_EXIT=$?

    check "#33: Real step-id 'step 04-02' IS caught by enforcement" \
        '[ "$STEP_EXIT" -eq 2 ] && echo "$STEP_STDOUT" | grep -q "DES_MARKERS_MISSING"'
else
    echo "  [SKIP] Cannot find nwave Python interpreter"
fi

# --- TEST 3: #32 .nwave/ has .gitignore ---
echo ""
echo "--- Test 3: .nwave/ gitignore (#32) ---"

# .nwave/ is project-local, check inside the project
PROJECT_NWAVE="/home/tester/project/.nwave"
check "#32: .nwave/.gitignore exists in project" \
    '[ -f "$PROJECT_NWAVE/.gitignore" ]'

if [ -f "$PROJECT_NWAVE/.gitignore" ]; then
    GITIGNORE_CONTENT=$(cat "$PROJECT_NWAVE/.gitignore")
    check "#32: .gitignore contains '*'" \
        'echo "$GITIGNORE_CONTENT" | grep -q "^\*$"'
else
    echo "    Note: .nwave/ may not be created during install if no DES config bootstrap occurred"
    # Check that the code IS there (production ready) even if not triggered
    check "#32: _ensure_gitignore exists in installed des_plugin.py" \
        'grep -q "ensure_gitignore" ~/.local/share/pipx/venvs/nwave-ai/lib/python3.12/site-packages/scripts/install/plugins/des_plugin.py 2>/dev/null'
fi

# --- TEST 4: #29 Skills survive reinstall ---
echo ""
echo "--- Test 4: User skills survive reinstall (#29) ---"

# Create a user skill
SKILLS_DIR="$HOME/.claude/skills"
mkdir -p "$SKILLS_DIR/nw-my-custom-org-skill"
cat > "$SKILLS_DIR/nw-my-custom-org-skill/SKILL.md" <<'SKILL'
---
name: nw-my-custom-org-skill
description: Custom org skill for testing
---
# My Custom Skill
This should survive reinstall.
SKILL

# Reinstall
cd /home/tester/project && ~/.local/bin/nwave-ai install 2>&1 > /dev/null || true

check "#29: User-created nw-* skill survives reinstall" \
    '[ -f "$SKILLS_DIR/nw-my-custom-org-skill/SKILL.md" ]'

if [ -f "$SKILLS_DIR/nw-my-custom-org-skill/SKILL.md" ]; then
    check "#29: Skill content preserved" \
        'grep -q "Custom org skill" "$SKILLS_DIR/nw-my-custom-org-skill/SKILL.md"'
fi

# --- TEST 5: Privacy — no private files in wheel ---
echo ""
echo "--- Test 5: Privacy — no private files exposed ---"

SITE_PACKAGES=$(find ~/.local/pipx -name "nwave_ai" -type d 2>/dev/null | head -1)
SITE_DIR=$(dirname "$SITE_PACKAGES" 2>/dev/null || echo "")

if [ -n "$SITE_DIR" ] && [ -d "$SITE_DIR" ]; then
    # Check no docs/analysis (internal RCA reports)
    check "No docs/analysis/ in wheel" \
        '! find "$SITE_DIR" -path "*/docs/analysis/*" 2>/dev/null | grep -q .'

    # Check no docs/feature (internal feature tracking)
    check "No docs/feature/ in wheel" \
        '! find "$SITE_DIR" -path "*/docs/feature/*" 2>/dev/null | grep -q .'

    # Check no .github (CI/CD)
    check "No .github/ in wheel" \
        '! find "$SITE_DIR" -path "*/.github/*" 2>/dev/null | grep -q .'

    # Check no des source code (closed source)
    check "No src/des/ in wheel (DES source)" \
        '! find "$SITE_DIR" -path "*/src/des/*" 2>/dev/null | grep -q .'

    # Check no tests
    check "No tests/ in wheel" \
        '! find "$SITE_DIR" -path "*/tests/*" -name "*.py" 2>/dev/null | grep -q .'

    # Check no .secrets or credentials
    check "No .secrets files in wheel" \
        '! find "$SITE_DIR" -name ".secrets" -o -name "credentials*" -o -name "*.key" 2>/dev/null | grep -q .'

    # Check no pyproject.toml (internal config)
    check "No pyproject.toml in wheel" \
        '! find "$SITE_DIR" -name "pyproject.toml" 2>/dev/null | grep -q .'
else
    echo "  [SKIP] Cannot find site-packages"
fi

echo ""
echo "============================================================"
echo "  Results: $PASS passed, $FAIL failed"
echo "============================================================"

exit $FAIL
TEST
RUN chmod +x /home/tester/test.sh

CMD ["/home/tester/test.sh"]
